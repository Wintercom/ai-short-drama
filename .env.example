# ============================================================================
# AI 短剧创作智能体 —— 环境配置示例
# 复制为 .env 后按需修改。所有项都有安全默认值：
# 不填任何 key 也能用本地 ffmpeg + macOS say 跑通完整闭环（零成本、可离线）。
# ============================================================================

# ---------- LLM（剧本生成）----------
# 留空 LLM_API_KEY 时自动使用内置 Stub 生成器（离线、免费、确定性输出）。
# 推荐低成本方案：DeepSeek（几分钱/部短剧）或本地 Ollama（完全免费）。
LLM_PROVIDER=stub                       # stub | openai-compatible
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_API_KEY=

# 本地 Ollama 示例（完全免费）：
# LLM_PROVIDER=openai-compatible
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5
# LLM_API_KEY=ollama

# ---------- 文生图 T2I / 图生视频 I2V ----------
# T2I_PROVIDER：
#   local        = SVG 矢量人物剪影 + 场景背景（免费离线，含男/女剪影、台词字幕）。
#   pollinations = Pollinations.AI 免费在线 API（真实人物图，无需 Key，需联网）；
#                  prompt 锁定外貌+统一画风改善一致性，但不保证同一张脸。失败降级 local。
#   wanedit      = 通义千问图像编辑（参考图驱动，跨镜头同一张脸——角色一致性最强）；
#                  角色锚点图作参考，每镜「图生图」保持人物。缺 Key 降级 pollinations。需 Key。
T2I_PROVIDER=local
# I2V_PROVIDER：
#   local = ffmpeg zoompan 运镜（推/拉/摇/移，免费离线，但仅镜头运动、人物静止）。
#   wan   = 通义万相图生视频（真人级人物动作；关键帧作首帧锚点，保角色一致）；
#           异步任务+轮询，失败/缺 Key 自动降级到 local，流程不中断。需联网 + API Key。
I2V_PROVIDER=local

# 通义千问图像编辑 T2I 配置（仅 T2I_PROVIDER=wanedit 时生效，角色一致性第二层）
# 在阿里云百炼控制台开通：https://bailian.console.aliyun.com/
# T2I_API_KEY 留空时自动回退读 DASHSCOPE_API_KEY；二者都空则 wanedit 降级 pollinations。
T2I_API_KEY=
T2I_MODEL=qwen-image                     # 文生图模型（生成角色锚点图）
T2I_EDIT_MODEL=qwen-image-edit-plus      # 图生图编辑模型（参考图驱动，保持同一张脸）
T2I_BASE_URL=https://dashscope.aliyuncs.com

# 通义万相 I2V 配置（仅 I2V_PROVIDER=wan 时生效）
# 在阿里云百炼控制台开通通义万相并获取 API Key：https://bailian.console.aliyun.com/
# I2V_API_KEY 留空时自动回退读 DASHSCOPE_API_KEY；二者都空则 wan 降级到 local。
I2V_API_KEY=
I2V_MODEL=wan2.2-i2v-plus
I2V_BASE_URL=https://dashscope.aliyuncs.com
# 输出分辨率：wan2.2-i2v-plus 仅支持 480P / 1080P（注意：不支持 720P）。
# 480P 出片快、成本低；1080P 更清晰但更慢更贵。最终画面由后期 FitDuration 适配项目尺寸。
I2V_RESOLUTION=480P

# ---------- 语音合成 TTS ----------
# say    = macOS 内置语音（免费离线）：系统女声 + 男声变调，零成本但音色略机械。
# edge   = 微软 edge-tts（免费在线）：真人级中文男/女声，音质最佳；
#          自带「串行+重试退避」防限速，失败自动降级到本地 say，流程不中断。
#          首次使用会自动 pip --user 安装 edge-tts（需 python3 + 联网）。
# silent = 生成等长静音轨（跨平台兜底，无任何依赖）。
# 男女声由角色 Gender 决定：剧本可在角色行第 4 段写「男/女」，或由名字自动猜测。
TTS_PROVIDER=say

# ---------- 运行参数 ----------
SHOT_CONCURRENCY=4                       # 镜头级并发数
VIDEO_WIDTH=1280
VIDEO_HEIGHT=720
VIDEO_FPS=25
WORKSPACE_DIR=workspace
FACES_DIR=faces                          # 用户角色画像目录：按「角色名.png/jpg」自动匹配为参考图
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
