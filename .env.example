# ============================================================================
# AI 短剧创作智能体 —— 环境配置示例
# 复制为 .env 后按需修改。所有项都有安全默认值：
# 不填任何 key 也能用本地 ffmpeg + macOS say 跑通完整闭环（零成本、可离线）。
# ============================================================================

# ---------- LLM（剧本生成）----------
# 留空 LLM_API_KEY 时自动使用内置 Stub 生成器（离线、免费、确定性输出）。
# 推荐低成本方案：DeepSeek（几分钱/部短剧）或本地 Ollama（完全免费）。
LLM_PROVIDER=stub                       # stub | openai-compatible
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_API_KEY=

# 本地 Ollama 示例（完全免费）：
# LLM_PROVIDER=openai-compatible
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5
# LLM_API_KEY=ollama

# ---------- 文生图 T2I / 图生视频 I2V ----------
# local = 用 ffmpeg 生成占位关键帧 + Ken Burns 运镜（免费）；后续可接真实模型。
T2I_PROVIDER=local
I2V_PROVIDER=local

# ---------- 语音合成 TTS ----------
# say    = macOS 内置语音（免费离线）：系统女声 + 男声变调，零成本但音色略机械。
# edge   = 微软 edge-tts（免费在线）：真人级中文男/女声，音质最佳；
#          自带「串行+重试退避」防限速，失败自动降级到本地 say，流程不中断。
#          首次使用会自动 pip --user 安装 edge-tts（需 python3 + 联网）。
# silent = 生成等长静音轨（跨平台兜底，无任何依赖）。
# 男女声由角色 Gender 决定：剧本可在角色行第 4 段写「男/女」，或由名字自动猜测。
TTS_PROVIDER=say

# ---------- 运行参数 ----------
SHOT_CONCURRENCY=4                       # 镜头级并发数
VIDEO_WIDTH=1280
VIDEO_HEIGHT=720
VIDEO_FPS=25
WORKSPACE_DIR=workspace
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
