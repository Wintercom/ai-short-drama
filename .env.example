# ============================================================================
# AI 短剧创作智能体 —— 环境配置示例
# 复制为 .env 后按需修改。所有项都有安全默认值：
# 不填任何 key 也能用本地 ffmpeg + macOS say 跑通完整闭环（零成本、可离线）。
# ============================================================================

# ---------- LLM（剧本生成）----------
# 留空 LLM_API_KEY 时自动使用内置 Stub 生成器（离线、免费、确定性输出）。
# 推荐低成本方案：DeepSeek（几分钱/部短剧）或本地 Ollama（完全免费）。
LLM_PROVIDER=stub                       # stub | openai-compatible
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_API_KEY=

# 本地 Ollama 示例（完全免费）：
# LLM_PROVIDER=openai-compatible
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5
# LLM_API_KEY=ollama

# ---------- 文生图 T2I / 图生视频 I2V ----------
# local = 用 ffmpeg 生成占位关键帧 + Ken Burns 运镜（免费）；后续可接真实模型。
T2I_PROVIDER=local
I2V_PROVIDER=local

# ---------- 语音合成 TTS ----------
# say = macOS 内置语音（免费）；silent = 生成等长静音轨（跨平台兜底）。
TTS_PROVIDER=say

# ---------- 运行参数 ----------
SHOT_CONCURRENCY=4                       # 镜头级并发数
VIDEO_WIDTH=1280
VIDEO_HEIGHT=720
VIDEO_FPS=25
WORKSPACE_DIR=workspace
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
